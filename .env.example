# ─── MCP Server Secrets ─────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# GitHub (used by Claude Code MCP)
GITHUB_TOKEN=your_github_personal_access_token

# Firebase (uses `firebase login` session auth — no secret needed here)
# Run `firebase login` and `firebase use <project-id>` per project instead.

# Stitch by Google Labs (used by Claude Code MCP)
# Get your API key from https://aistudio.google.com/apikey
STITCH_API_KEY=your_google_ai_api_key

# ─── App Configuration ──────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=
